"""
Generated adiabatic two-stream mixer model.

This file is generated by the idaes-agent scaffold system.

MVP model:
    T_out = (m1 Cp1 T1 + m2 Cp2 T2) / (m1 Cp1 + m2 Cp2)

Supported solve modes:
    1. calculate_outlet_temperature

Important:
    This MVP uses Pyomo objects but does not require an external solver.
    The goal is to prove multi-family autonomous execution + parsing + verification.
"""

import json
import traceback

import pyomo.environ as pyo


# -----------------------------
# STRUCTURED SPEC INPUT
# -----------------------------
SPEC = {{SPEC_JSON}}


def build_model(spec):
    model = pyo.ConcreteModel(name="adiabatic_mixer")

    mode = spec["mode"]

    if mode != "calculate_outlet_temperature":
        raise ValueError(f"Unsupported mode: {mode}")

    model.stream1_mass_flow_kg_s = pyo.Param(
        initialize=float(spec["stream1_mass_flow_kg_s"]),
        mutable=True
    )
    model.stream2_mass_flow_kg_s = pyo.Param(
        initialize=float(spec["stream2_mass_flow_kg_s"]),
        mutable=True
    )

    model.stream1_temperature_k = pyo.Param(
        initialize=float(spec["stream1_temperature_k"]),
        mutable=True
    )
    model.stream2_temperature_k = pyo.Param(
        initialize=float(spec["stream2_temperature_k"]),
        mutable=True
    )

    model.stream1_cp_j_kg_k = pyo.Param(
        initialize=float(spec["stream1_cp_j_kg_k"]),
        mutable=True
    )
    model.stream2_cp_j_kg_k = pyo.Param(
        initialize=float(spec["stream2_cp_j_kg_k"]),
        mutable=True
    )

    model.outlet_temperature_k = pyo.Var(initialize=300.0)

    def mixer_energy_balance_rule(m):
        return (
            m.stream1_mass_flow_kg_s
            * m.stream1_cp_j_kg_k
            * (m.stream1_temperature_k - m.outlet_temperature_k)
            + m.stream2_mass_flow_kg_s
            * m.stream2_cp_j_kg_k
            * (m.stream2_temperature_k - m.outlet_temperature_k)
            == 0.0
        )

    model.energy_balance = pyo.Constraint(rule=mixer_energy_balance_rule)

    denominator = (
        pyo.value(model.stream1_mass_flow_kg_s)
        * pyo.value(model.stream1_cp_j_kg_k)
        + pyo.value(model.stream2_mass_flow_kg_s)
        * pyo.value(model.stream2_cp_j_kg_k)
    )

    if abs(denominator) < 1e-12:
        raise ValueError("Cannot calculate outlet temperature because total heat capacity flow is zero.")

    outlet_temperature = (
        pyo.value(model.stream1_mass_flow_kg_s)
        * pyo.value(model.stream1_cp_j_kg_k)
        * pyo.value(model.stream1_temperature_k)
        + pyo.value(model.stream2_mass_flow_kg_s)
        * pyo.value(model.stream2_cp_j_kg_k)
        * pyo.value(model.stream2_temperature_k)
    ) / denominator

    model.outlet_temperature_k.fix(outlet_temperature)

    return model


def extract_results(model, spec):
    stream1_mass_flow_kg_s = pyo.value(model.stream1_mass_flow_kg_s)
    stream2_mass_flow_kg_s = pyo.value(model.stream2_mass_flow_kg_s)

    stream1_temperature_k = pyo.value(model.stream1_temperature_k)
    stream2_temperature_k = pyo.value(model.stream2_temperature_k)

    stream1_cp_j_kg_k = pyo.value(model.stream1_cp_j_kg_k)
    stream2_cp_j_kg_k = pyo.value(model.stream2_cp_j_kg_k)

    outlet_temperature_k = pyo.value(model.outlet_temperature_k)

    energy_balance_residual_w = (
        stream1_mass_flow_kg_s
        * stream1_cp_j_kg_k
        * (stream1_temperature_k - outlet_temperature_k)
        + stream2_mass_flow_kg_s
        * stream2_cp_j_kg_k
        * (stream2_temperature_k - outlet_temperature_k)
    )

    result = {
        "problem_type": spec["problem_type"],
        "mode": spec["mode"],
        "backend": "pyomo",
        "solver_name": "direct_adiabatic_mixer_energy_balance",
        "solver_status": "ok",
        "termination_condition": "optimal",

        "material": spec.get("material", "unknown"),
        "flow_basis": spec.get("flow_basis", "mass"),
        "pressure_pa": float(spec.get("pressure_pa", 100000.0)),

        "stream1_mass_flow_kg_s": stream1_mass_flow_kg_s,
        "stream1_temperature_k": stream1_temperature_k,
        "stream1_cp_j_kg_k": stream1_cp_j_kg_k,

        "stream2_mass_flow_kg_s": stream2_mass_flow_kg_s,
        "stream2_temperature_k": stream2_temperature_k,
        "stream2_cp_j_kg_k": stream2_cp_j_kg_k,

        "outlet_temperature_k": outlet_temperature_k,
        "temperature_out_k": outlet_temperature_k,
        "energy_balance_residual_w": energy_balance_residual_w,
        "thermal_direction": "adiabatic_mixing"
    }

    return result


def main():
    try:
        model = build_model(SPEC)
        result = extract_results(model, SPEC)

        print("RESULT_JSON_START")
        print(json.dumps(result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")

    except Exception as exc:
        error_result = {
            "problem_type": SPEC.get("problem_type", "unknown"),
            "mode": SPEC.get("mode", "unknown"),
            "solver_status": "error",
            "termination_condition": "exception",
            "error_type": type(exc).__name__,
            "error_message": str(exc),
            "traceback": traceback.format_exc()
        }

        print("RESULT_JSON_START")
        print(json.dumps(error_result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")

        raise


if __name__ == "__main__":
    main()
