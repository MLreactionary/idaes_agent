"""
Generated splitter mass-balance model.

This file is generated by the idaes-agent scaffold system.

MVP model:
    outlet1_mass_flow = inlet_mass_flow * outlet1_split_fraction
    outlet2_mass_flow = inlet_mass_flow * (1 - outlet1_split_fraction)

Supported solve modes:
    1. calculate_outlet_flows

Important:
    This MVP uses Pyomo objects but does not require an external solver.
"""

import json
import traceback

import pyomo.environ as pyo


SPEC = {{SPEC_JSON}}


def build_model(spec):
    model = pyo.ConcreteModel(name="splitter_mass_balance")

    mode = spec["mode"]

    if mode != "calculate_outlet_flows":
        raise ValueError(f"Unsupported mode: {mode}")

    inlet_mass_flow_kg_s = float(spec["inlet_mass_flow_kg_s"])
    outlet1_split_fraction = float(spec["outlet1_split_fraction"])

    if inlet_mass_flow_kg_s < 0:
        raise ValueError("Inlet mass flow must be nonnegative.")

    if outlet1_split_fraction < 0 or outlet1_split_fraction > 1:
        raise ValueError("Outlet 1 split fraction must be between 0 and 1.")

    model.inlet_mass_flow_kg_s = pyo.Param(
        initialize=inlet_mass_flow_kg_s,
        mutable=True
    )

    model.outlet1_split_fraction = pyo.Param(
        initialize=outlet1_split_fraction,
        mutable=True
    )

    model.outlet2_split_fraction = pyo.Param(
        initialize=1.0 - outlet1_split_fraction,
        mutable=True
    )

    model.outlet1_mass_flow_kg_s = pyo.Var(initialize=0.0)
    model.outlet2_mass_flow_kg_s = pyo.Var(initialize=0.0)

    def outlet1_rule(m):
        return m.outlet1_mass_flow_kg_s == m.inlet_mass_flow_kg_s * m.outlet1_split_fraction

    def outlet2_rule(m):
        return m.outlet2_mass_flow_kg_s == m.inlet_mass_flow_kg_s * m.outlet2_split_fraction

    def total_mass_balance_rule(m):
        return (
            m.inlet_mass_flow_kg_s
            == m.outlet1_mass_flow_kg_s + m.outlet2_mass_flow_kg_s
        )

    model.outlet1_balance = pyo.Constraint(rule=outlet1_rule)
    model.outlet2_balance = pyo.Constraint(rule=outlet2_rule)
    model.total_mass_balance = pyo.Constraint(rule=total_mass_balance_rule)

    outlet1_mass_flow_kg_s = inlet_mass_flow_kg_s * outlet1_split_fraction
    outlet2_mass_flow_kg_s = inlet_mass_flow_kg_s * (1.0 - outlet1_split_fraction)

    model.outlet1_mass_flow_kg_s.fix(outlet1_mass_flow_kg_s)
    model.outlet2_mass_flow_kg_s.fix(outlet2_mass_flow_kg_s)

    return model


def extract_results(model, spec):
    inlet_mass_flow_kg_s = pyo.value(model.inlet_mass_flow_kg_s)
    outlet1_split_fraction = pyo.value(model.outlet1_split_fraction)
    outlet2_split_fraction = pyo.value(model.outlet2_split_fraction)

    outlet1_mass_flow_kg_s = pyo.value(model.outlet1_mass_flow_kg_s)
    outlet2_mass_flow_kg_s = pyo.value(model.outlet2_mass_flow_kg_s)

    mass_balance_residual_kg_s = (
        inlet_mass_flow_kg_s
        - outlet1_mass_flow_kg_s
        - outlet2_mass_flow_kg_s
    )

    result = {
        "problem_type": spec["problem_type"],
        "mode": spec["mode"],
        "backend": "pyomo",
        "solver_name": "direct_splitter_mass_balance",
        "solver_status": "ok",
        "termination_condition": "optimal",

        "material": spec.get("material", "unknown"),
        "flow_basis": spec.get("flow_basis", "mass"),

        "inlet_mass_flow_kg_s": inlet_mass_flow_kg_s,
        "outlet1_split_fraction": outlet1_split_fraction,
        "outlet2_split_fraction": outlet2_split_fraction,
        "outlet1_mass_flow_kg_s": outlet1_mass_flow_kg_s,
        "outlet2_mass_flow_kg_s": outlet2_mass_flow_kg_s,
        "mass_balance_residual_kg_s": mass_balance_residual_kg_s
    }

    return result


def main():
    try:
        model = build_model(SPEC)
        result = extract_results(model, SPEC)

        print("RESULT_JSON_START")
        print(json.dumps(result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")

    except Exception as exc:
        error_result = {
            "problem_type": SPEC.get("problem_type", "unknown"),
            "mode": SPEC.get("mode", "unknown"),
            "solver_status": "error",
            "termination_condition": "failed",
            "error": str(exc),
            "traceback": traceback.format_exc()
        }

        print("RESULT_JSON_START")
        print(json.dumps(error_result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")
        raise


if __name__ == "__main__":
    main()
