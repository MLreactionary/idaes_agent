"""
Generated heater/cooler energy-balance model.

This file is generated by the idaes-agent scaffold system.

MVP model:
    Q = m_dot * Cp * (Tout - Tin)

Supported solve modes:
    1. calculate_heat_duty
    2. calculate_outlet_temperature
    3. calculate_mass_flow

Important:
    This MVP uses Pyomo objects but does not require an external solver.
    The goal is to prove autonomous execution + parsing + verification.
"""

import json
import traceback

import pyomo.environ as pyo


# -----------------------------
# STRUCTURED SPEC INPUT
# -----------------------------
SPEC = {{SPEC_JSON}}


def build_model(spec):
    """
    Build a small Pyomo model for sensible heating/cooling.

    Supported modes:
        1. calculate_heat_duty
        2. calculate_outlet_temperature
        3. calculate_mass_flow
    """

    model = pyo.ConcreteModel(name="heater_energy_balance")

    mode = spec["mode"]

    model.cp_j_kg_k = pyo.Param(
        initialize=float(spec["cp_j_kg_k"]),
        mutable=True
    )

    model.temperature_in_k = pyo.Param(
        initialize=float(spec["temperature_in_k"]),
        mutable=True
    )

    if mode == "calculate_heat_duty":
        model.mass_flow_kg_s = pyo.Param(
            initialize=float(spec["mass_flow_kg_s"]),
            mutable=True
        )

        model.temperature_out_k = pyo.Param(
            initialize=float(spec["temperature_out_k"]),
            mutable=True
        )

        model.heat_duty_w = pyo.Var(initialize=0.0)

        def energy_balance_rule(m):
            return m.heat_duty_w == (
                m.mass_flow_kg_s
                * m.cp_j_kg_k
                * (m.temperature_out_k - m.temperature_in_k)
            )

        model.energy_balance = pyo.Constraint(rule=energy_balance_rule)

        q_value = (
            pyo.value(model.mass_flow_kg_s)
            * pyo.value(model.cp_j_kg_k)
            * (pyo.value(model.temperature_out_k) - pyo.value(model.temperature_in_k))
        )

        model.heat_duty_w.fix(q_value)

    elif mode == "calculate_outlet_temperature":
        model.mass_flow_kg_s = pyo.Param(
            initialize=float(spec["mass_flow_kg_s"]),
            mutable=True
        )

        model.heat_duty_w = pyo.Param(
            initialize=float(spec["heat_duty_w"]),
            mutable=True
        )

        model.temperature_out_k = pyo.Var(
            initialize=float(spec["temperature_in_k"])
        )

        def energy_balance_rule(m):
            return m.heat_duty_w == (
                m.mass_flow_kg_s
                * m.cp_j_kg_k
                * (m.temperature_out_k - m.temperature_in_k)
            )

        model.energy_balance = pyo.Constraint(rule=energy_balance_rule)

        denominator = pyo.value(model.mass_flow_kg_s) * pyo.value(model.cp_j_kg_k)

        if abs(denominator) < 1e-12:
            raise ValueError("Cannot calculate outlet temperature because mass_flow * Cp is zero.")

        tout_value = (
            pyo.value(model.temperature_in_k)
            + pyo.value(model.heat_duty_w) / denominator
        )

        model.temperature_out_k.fix(tout_value)

    elif mode == "calculate_mass_flow":
        model.temperature_out_k = pyo.Param(
            initialize=float(spec["temperature_out_k"]),
            mutable=True
        )

        model.heat_duty_w = pyo.Param(
            initialize=float(spec["heat_duty_w"]),
            mutable=True
        )

        model.mass_flow_kg_s = pyo.Var(initialize=1.0)

        def energy_balance_rule(m):
            return m.heat_duty_w == (
                m.mass_flow_kg_s
                * m.cp_j_kg_k
                * (m.temperature_out_k - m.temperature_in_k)
            )

        model.energy_balance = pyo.Constraint(rule=energy_balance_rule)

        denominator = (
            pyo.value(model.cp_j_kg_k)
            * (pyo.value(model.temperature_out_k) - pyo.value(model.temperature_in_k))
        )

        if abs(denominator) < 1e-12:
            raise ValueError(
                "Cannot calculate mass flow because Cp * deltaT is zero."
            )

        mass_flow_value = pyo.value(model.heat_duty_w) / denominator

        model.mass_flow_kg_s.fix(mass_flow_value)

    else:
        raise ValueError(f"Unsupported mode: {mode}")

    return model


def extract_results(model, spec):
    heat_duty_w = pyo.value(model.heat_duty_w)
    temperature_out_k = pyo.value(model.temperature_out_k)
    temperature_in_k = pyo.value(model.temperature_in_k)
    mass_flow_kg_s = pyo.value(model.mass_flow_kg_s)
    cp_j_kg_k = pyo.value(model.cp_j_kg_k)

    energy_balance_residual_w = (
        heat_duty_w
        - mass_flow_kg_s * cp_j_kg_k * (temperature_out_k - temperature_in_k)
    )

    if heat_duty_w > 0:
        thermal_direction = "heating"
    elif heat_duty_w < 0:
        thermal_direction = "cooling"
    else:
        thermal_direction = "no_temperature_change"

    result = {
        "problem_type": spec["problem_type"],
        "mode": spec["mode"],
        "backend": "pyomo",
        "solver_name": "direct_linear_energy_balance",
        "solver_status": "ok",
        "termination_condition": "optimal",

        "material": spec.get("material", "unknown"),
        "flow_basis": spec.get("flow_basis", "mass"),
        "mass_flow_kg_s": mass_flow_kg_s,
        "cp_j_kg_k": cp_j_kg_k,
        "pressure_pa": float(spec.get("pressure_pa", 100000.0)),

        "temperature_in_k": temperature_in_k,
        "temperature_out_k": temperature_out_k,
        "heat_duty_w": heat_duty_w,
        "energy_balance_residual_w": energy_balance_residual_w,
        "thermal_direction": thermal_direction
    }

    return result


def main():
    try:
        model = build_model(SPEC)
        result = extract_results(model, SPEC)

        print("RESULT_JSON_START")
        print(json.dumps(result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")

    except Exception as exc:
        error_result = {
            "problem_type": SPEC.get("problem_type", "unknown"),
            "mode": SPEC.get("mode", "unknown"),
            "solver_status": "error",
            "termination_condition": "exception",
            "error_type": type(exc).__name__,
            "error_message": str(exc),
            "traceback": traceback.format_exc()
        }

        print("RESULT_JSON_START")
        print(json.dumps(error_result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")

        raise


if __name__ == "__main__":
    main()
