"""
Generated IDAES-backed heater energy-balance model.

This file is generated by the idaes-agent scaffold system.

IDAES backend MVP:
    - Imports IDAES
    - Creates a FlowsheetBlock
    - Builds Pyomo variables/constraints inside that flowsheet
    - Supports the same simple sensible-heat modes as the Pyomo heater scaffold

Important:
    This is an IDAES-backed scaffold smoke path, not yet a full IDAES property-package heater model.
"""

import json
import traceback

import pyomo.environ as pyo
from idaes.core import FlowsheetBlock


SPEC = {{SPEC_JSON}}


def require_nonzero(value, label):
    if abs(float(value)) < 1e-12:
        raise ValueError(f"{label} must be nonzero for this calculation.")
    return float(value)


def build_model(spec):
    model = pyo.ConcreteModel(name="idaes_heater_energy_balance")
    model.fs = FlowsheetBlock(dynamic=False)

    mode = spec["mode"]

    if mode not in {
        "calculate_heat_duty",
        "calculate_outlet_temperature",
        "calculate_mass_flow",
    }:
        raise ValueError(f"Unsupported IDAES heater mode: {mode}")

    cp_j_kg_k = float(spec["cp_j_kg_k"])
    temperature_in_k = float(spec["temperature_in_k"])

    if mode == "calculate_heat_duty":
        mass_flow_kg_s = float(spec["mass_flow_kg_s"])
        temperature_out_k = float(spec["temperature_out_k"])
        heat_duty_w = mass_flow_kg_s * cp_j_kg_k * (temperature_out_k - temperature_in_k)

    elif mode == "calculate_outlet_temperature":
        mass_flow_kg_s = require_nonzero(spec["mass_flow_kg_s"], "mass_flow_kg_s")
        heat_duty_w = float(spec["heat_duty_w"])
        temperature_out_k = temperature_in_k + heat_duty_w / (mass_flow_kg_s * cp_j_kg_k)

    else:
        temperature_out_k = float(spec["temperature_out_k"])
        heat_duty_w = float(spec["heat_duty_w"])
        delta_temperature_k = require_nonzero(
            temperature_out_k - temperature_in_k,
            "temperature_out_k - temperature_in_k"
        )
        mass_flow_kg_s = heat_duty_w / (cp_j_kg_k * delta_temperature_k)

    model.fs.mass_flow_kg_s = pyo.Var(initialize=mass_flow_kg_s)
    model.fs.cp_j_kg_k = pyo.Param(initialize=cp_j_kg_k, mutable=True)
    model.fs.temperature_in_k = pyo.Param(initialize=temperature_in_k, mutable=True)
    model.fs.temperature_out_k = pyo.Var(initialize=temperature_out_k)
    model.fs.heat_duty_w = pyo.Var(initialize=heat_duty_w)

    model.fs.mass_flow_kg_s.fix(mass_flow_kg_s)
    model.fs.temperature_out_k.fix(temperature_out_k)
    model.fs.heat_duty_w.fix(heat_duty_w)

    def energy_balance_rule(b):
        return (
            b.heat_duty_w
            == b.mass_flow_kg_s
            * b.cp_j_kg_k
            * (b.temperature_out_k - b.temperature_in_k)
        )

    model.fs.energy_balance = pyo.Constraint(rule=energy_balance_rule)

    return model


def extract_results(model, spec):
    mass_flow_kg_s = pyo.value(model.fs.mass_flow_kg_s)
    cp_j_kg_k = pyo.value(model.fs.cp_j_kg_k)
    temperature_in_k = pyo.value(model.fs.temperature_in_k)
    temperature_out_k = pyo.value(model.fs.temperature_out_k)
    heat_duty_w = pyo.value(model.fs.heat_duty_w)

    energy_balance_residual_w = (
        heat_duty_w
        - mass_flow_kg_s
        * cp_j_kg_k
        * (temperature_out_k - temperature_in_k)
    )

    if abs(heat_duty_w) < 1e-12:
        thermal_direction = "isothermal"
    elif heat_duty_w > 0:
        thermal_direction = "heating"
    else:
        thermal_direction = "cooling"

    result = {
        "problem_type": spec["problem_type"],
        "mode": spec["mode"],
        "backend": "idaes",
        "solver_name": "idaes_direct_sensible_heat_smoke",
        "solver_status": "ok",
        "termination_condition": "optimal",

        "material": spec.get("material", "unknown"),
        "flow_basis": spec.get("flow_basis", "mass"),
        "mass_flow_kg_s": mass_flow_kg_s,
        "cp_j_kg_k": cp_j_kg_k,
        "pressure_pa": float(spec.get("pressure_pa", 100000.0)),
        "temperature_in_k": temperature_in_k,
        "temperature_out_k": temperature_out_k,
        "heat_duty_w": heat_duty_w,
        "energy_balance_residual_w": energy_balance_residual_w,
        "thermal_direction": thermal_direction,

        "idaes_flowsheet_block_created": True,
        "idaes_solver_required": False
    }

    return result


def main():
    try:
        model = build_model(SPEC)
        result = extract_results(model, SPEC)

        print("RESULT_JSON_START")
        print(json.dumps(result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")

    except Exception as exc:
        error_result = {
            "problem_type": SPEC.get("problem_type", "unknown"),
            "mode": SPEC.get("mode", "unknown"),
            "backend": "idaes",
            "solver_status": "error",
            "termination_condition": "failed",
            "error": str(exc),
            "traceback": traceback.format_exc()
        }

        print("RESULT_JSON_START")
        print(json.dumps(error_result, indent=2, sort_keys=True))
        print("RESULT_JSON_END")
        raise


if __name__ == "__main__":
    main()
